<?xml version="1.0" encoding="UTF-8"?>
<form>
    <fields name="filter">
        <field name="search"
               type="text"
               label="COM_APOFJDOWNLOADS_FILTER_SEARCH_LABEL"
               description="COM_APOFJDOWNLOADS_FILTER_SEARCH_LOGS_DESC"
               hint="JSEARCH_FILTER" />

        <field name="download_id"
               type="sql"
               label="COM_APOFJDOWNLOADS_FILTER_DOWNLOAD_LABEL"
               query="SELECT id AS value, title AS text FROM #__apofjdl_downloads ORDER BY title"
               key_field="value"
               value_field="text"
               onchange="this.form.submit();">
            <option value="">COM_APOFJDOWNLOADS_FILTER_DOWNLOAD_LABEL</option>
        </field>

        <field name="status"
               type="list"
               label="COM_APOFJDOWNLOADS_FILTER_STATUS_LABEL"
               onchange="this.form.submit();">
            <option value="">COM_APOFJDOWNLOADS_FILTER_STATUS_LABEL</option>
            <option value="completed">COM_APOFJDOWNLOADS_STATUS_COMPLETED</option>
            <option value="denied_acl">COM_APOFJDOWNLOADS_STATUS_DENIED_ACL</option>
            <option value="denied_quota">COM_APOFJDOWNLOADS_STATUS_DENIED_QUOTA</option>
            <option value="denied_rate_limit">COM_APOFJDOWNLOADS_STATUS_DENIED_RATE_LIMIT</option>
            <option value="token_expired">COM_APOFJDOWNLOADS_STATUS_TOKEN_EXPIRED</option>
            <option value="token_invalid">COM_APOFJDOWNLOADS_STATUS_TOKEN_INVALID</option>
        </field>
    </fields>

    <fields name="list">
        <field name="fullordering"
               type="list"
               label="JGLOBAL_SORT_BY"
               default="a.downloaded_at DESC"
               onchange="this.form.submit();">
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.downloaded_at ASC">JDATE_ASC</option>
            <option value="a.downloaded_at DESC">JDATE_DESC</option>
            <option value="download_title ASC">COM_APOFJDOWNLOADS_HEADING_DOWNLOAD_TITLE_ASC</option>
            <option value="download_title DESC">COM_APOFJDOWNLOADS_HEADING_DOWNLOAD_TITLE_DESC</option>
            <option value="username ASC">COM_APOFJDOWNLOADS_HEADING_USERNAME_ASC</option>
            <option value="username DESC">COM_APOFJDOWNLOADS_HEADING_USERNAME_DESC</option>
            <option value="a.status ASC">COM_APOFJDOWNLOADS_HEADING_STATUS_ASC</option>
            <option value="a.status DESC">COM_APOFJDOWNLOADS_HEADING_STATUS_DESC</option>
            <option value="a.id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.id DESC">JGRID_HEADING_ID_DESC</option>
        </field>

        <field name="limit"
               type="limitbox"
               label="JGLOBAL_LIST_LIMIT"
               default="25"
               onchange="this.form.submit();" />
    </fields>
</form>
