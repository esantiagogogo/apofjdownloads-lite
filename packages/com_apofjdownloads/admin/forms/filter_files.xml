<?xml version="1.0" encoding="UTF-8"?>
<form>
    <fields name="filter">
        <field name="search"
               type="text"
               label="COM_APOFJDOWNLOADS_FILTER_SEARCH_LABEL"
               description="COM_APOFJDOWNLOADS_FILTER_SEARCH_DESC"
               hint="JSEARCH_FILTER" />

        <field name="state"
               type="status"
               label="JOPTION_SELECT_PUBLISHED"
               onchange="this.form.submit();">
            <option value="">JOPTION_SELECT_PUBLISHED</option>
        </field>

        <field name="download_id"
               type="sql"
               label="COM_APOFJDOWNLOADS_FILTER_DOWNLOAD_LABEL"
               query="SELECT id AS value, title AS text FROM #__apofjdl_downloads WHERE state = 1 ORDER BY title"
               key_field="value"
               value_field="text"
               onchange="this.form.submit();">
            <option value="">COM_APOFJDOWNLOADS_FILTER_SELECT_DOWNLOAD</option>
        </field>
    </fields>

    <fields name="list">
        <field name="fullordering"
               type="list"
               label="JGLOBAL_SORT_BY"
               default="a.ordering ASC"
               onchange="this.form.submit();">
            <option value="">JGLOBAL_SORT_BY</option>
            <option value="a.ordering ASC">JGRID_HEADING_ORDERING_ASC</option>
            <option value="a.ordering DESC">JGRID_HEADING_ORDERING_DESC</option>
            <option value="a.filename ASC">COM_APOFJDOWNLOADS_HEADING_FILENAME_ASC</option>
            <option value="a.filename DESC">COM_APOFJDOWNLOADS_HEADING_FILENAME_DESC</option>
            <option value="a.state ASC">JSTATUS_ASC</option>
            <option value="a.state DESC">JSTATUS_DESC</option>
            <option value="a.size ASC">COM_APOFJDOWNLOADS_HEADING_SIZE_ASC</option>
            <option value="a.size DESC">COM_APOFJDOWNLOADS_HEADING_SIZE_DESC</option>
            <option value="a.download_count ASC">COM_APOFJDOWNLOADS_HEADING_DOWNLOAD_COUNT_ASC</option>
            <option value="a.download_count DESC">COM_APOFJDOWNLOADS_HEADING_DOWNLOAD_COUNT_DESC</option>
            <option value="a.created ASC">JDATE_ASC</option>
            <option value="a.created DESC">JDATE_DESC</option>
            <option value="a.id ASC">JGRID_HEADING_ID_ASC</option>
            <option value="a.id DESC">JGRID_HEADING_ID_DESC</option>
        </field>

        <field name="limit"
               type="limitbox"
               label="JGLOBAL_LIST_LIMIT"
               default="25"
               onchange="this.form.submit();" />
    </fields>
</form>
