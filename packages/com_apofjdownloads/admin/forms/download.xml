<?xml version="1.0" encoding="UTF-8"?>
<form>
    <fieldset name="details">
        <field name="id"
               type="hidden" />

        <field name="title"
               type="text"
               label="COM_APOFJDOWNLOADS_FIELD_TITLE_LABEL"
               required="true"
               size="40"
               maxlength="255" />

        <field name="alias"
               type="text"
               label="COM_APOFJDOWNLOADS_FIELD_ALIAS_LABEL"
               size="40"
               maxlength="400"
               hint="JFIELD_ALIAS_PLACEHOLDER" />

        <field name="description"
               type="editor"
               label="COM_APOFJDOWNLOADS_FIELD_DESCRIPTION_LABEL"
               filter="safehtml"
               buttons="true" />

        <field name="state"
               type="list"
               label="JSTATUS"
               default="1"
               class="form-select">
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="2">JARCHIVED</option>
            <option value="-2">JTRASHED</option>
        </field>

        <field name="catid"
               type="categoryedit"
               label="JCATEGORY"
               extension="com_apofjdownloads"
               required="true"
               default="" />

        <field name="access"
               type="accesslevel"
               label="JFIELD_ACCESS_LABEL"
               default="1" />

        <field name="language"
               type="contentlanguage"
               label="JFIELD_LANGUAGE_LABEL"
               default="*">
            <option value="*">JALL</option>
        </field>

        <field name="featured"
               type="radio"
               label="JFEATURED"
               default="0"
               class="btn-group">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>

        <field name="license_id"
               type="sql"
               label="COM_APOFJDOWNLOADS_FIELD_LICENSE_LABEL"
               query="SELECT id AS value, title AS text FROM #__apofjdl_licenses WHERE state = 1 ORDER BY title"
               default="0"
               key_field="value"
               value_field="text">
            <option value="0">- None -</option>
        </field>

        <field name="version_note"
               type="text"
               label="COM_APOFJDOWNLOADS_FIELD_VERSION_NOTE_LABEL"
               size="40"
               maxlength="255" />

        <field name="changelog"
               type="textarea"
               label="COM_APOFJDOWNLOADS_FIELD_CHANGELOG_LABEL"
               rows="5"
               cols="60" />

        <field name="ordering"
               type="ordering"
               label="JFIELD_ORDERING_LABEL" />

        <field name="created"
               type="calendar"
               label="JGLOBAL_FIELD_CREATED_LABEL"
               translateformat="true"
               showtime="true" />

        <field name="created_by"
               type="user"
               label="JGLOBAL_FIELD_CREATED_BY_LABEL" />

        <field name="modified"
               type="calendar"
               label="JGLOBAL_FIELD_MODIFIED_LABEL"
               translateformat="true"
               showtime="true"
               readonly="true" />

        <field name="modified_by"
               type="user"
               label="JGLOBAL_FIELD_MODIFIED_BY_LABEL"
               readonly="true" />

        <field name="hits"
               type="number"
               label="JGLOBAL_HITS"
               default="0"
               readonly="true" />
    </fieldset>

    <fields name="params">
        <fieldset name="params"
                  label="JGLOBAL_FIELDSET_DISPLAY_OPTIONS">
        </fieldset>
    </fields>

    <fields name="metadata">
        <fieldset name="metadata"
                  label="JGLOBAL_FIELDSET_METADATA_OPTIONS">
            <field name="metadesc"
                   type="textarea"
                   label="JFIELD_META_DESCRIPTION_LABEL"
                   rows="3"
                   cols="60"
                   maxlength="160" />

            <field name="metakey"
                   type="text"
                   label="JFIELD_META_KEYWORDS_LABEL"
                   size="40" />
        </fieldset>
    </fields>
</form>
