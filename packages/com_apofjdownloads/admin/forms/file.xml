<?xml version="1.0" encoding="UTF-8"?>
<form>
    <fieldset name="details">
        <field name="id"
               type="hidden" />

        <field name="download_id"
               type="sql"
               label="COM_APOFJDOWNLOADS_FIELD_DOWNLOAD_LABEL"
               query="SELECT id AS value, title AS text FROM #__apofjdl_downloads WHERE state = 1 ORDER BY title"
               required="true"
               default=""
               key_field="value"
               value_field="text">
            <option value="">- Select Download -</option>
        </field>

        <field name="upload_file"
               type="file"
               label="COM_APOFJDOWNLOADS_FIELD_UPLOAD_FILE_LABEL"
               description="COM_APOFJDOWNLOADS_FIELD_UPLOAD_FILE_DESC"
               accept="*/*" />

        <field name="filename"
               type="text"
               label="COM_APOFJDOWNLOADS_FIELD_FILENAME_LABEL"
               size="40"
               maxlength="255"
               readonly="true" />

        <field name="filepath"
               type="text"
               label="COM_APOFJDOWNLOADS_FIELD_FILEPATH_LABEL"
               size="60"
               maxlength="1024" />

        <field name="storage_adapter"
               type="list"
               label="COM_APOFJDOWNLOADS_FIELD_STORAGE_ADAPTER_LABEL"
               default="local"
               class="form-select">
            <option value="local">COM_APOFJDOWNLOADS_FIELD_STORAGE_ADAPTER_LOCAL</option>
        </field>

        <field name="size"
               type="number"
               label="COM_APOFJDOWNLOADS_FIELD_SIZE_LABEL"
               default="0"
               readonly="true" />

        <field name="mime_type"
               type="text"
               label="COM_APOFJDOWNLOADS_FIELD_MIME_TYPE_LABEL"
               readonly="true"
               maxlength="255" />

        <field name="mime_verified"
               type="radio"
               label="COM_APOFJDOWNLOADS_FIELD_MIME_VERIFIED_LABEL"
               readonly="true"
               default="0"
               class="btn-group">
            <option value="0">JNO</option>
            <option value="1">JYES</option>
        </field>

        <field name="hash_sha256"
               type="text"
               label="COM_APOFJDOWNLOADS_FIELD_HASH_SHA256_LABEL"
               readonly="true"
               maxlength="64" />

        <field name="hash_md5"
               type="text"
               label="COM_APOFJDOWNLOADS_FIELD_HASH_MD5_LABEL"
               readonly="true"
               maxlength="32" />

        <field name="download_count"
               type="number"
               label="COM_APOFJDOWNLOADS_FIELD_DOWNLOAD_COUNT_LABEL"
               default="0"
               readonly="true" />

        <field name="ordering"
               type="ordering"
               label="JFIELD_ORDERING_LABEL" />

        <field name="state"
               type="list"
               label="JSTATUS"
               default="1"
               class="form-select">
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
            <option value="-2">JTRASHED</option>
        </field>

        <field name="created"
               type="calendar"
               label="JGLOBAL_FIELD_CREATED_LABEL"
               translateformat="true"
               showtime="true"
               readonly="true" />
    </fieldset>
</form>
