<div class="apofjdl-categories">
    {% if categories is not empty %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for category in categories %}
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ category.title }}</h5>
                            {% if category.description %}
                                <p class="card-text">{{ category.description|raw }}</p>
                            {% endif %}
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <small class="text-muted">{{ category.download_count ?? 0 }} downloads</small>
                            <a href="{{ category.link ?? '#' }}" class="btn btn-sm btn-outline-primary">Browse</a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">No categories found.</div>
    {% endif %}
</div>
