<div class="apofjdl-search">
    <form method="get" action="{{ search_action ?? '' }}" class="mb-4">
        <div class="input-group">
            <input type="text" name="searchword" class="form-control"
                   value="{{ searchword ?? '' }}"
                   placeholder="Search downloads..." />
            <button type="submit" class="btn btn-primary">Search</button>
        </div>
    </form>

    {% if searchword is defined and searchword %}
        {% if downloads is not empty %}
            <p class="text-muted">{{ downloads|length }} result{{ downloads|length != 1 ? 's' : '' }} for &ldquo;{{ searchword }}&rdquo;</p>

            <div class="list-group">
                {% for download in downloads %}
                    <a href="{{ download.link ?? '#' }}" class="list-group-item list-group-item-action">
                        <div class="d-flex w-100 justify-content-between">
                            <h5 class="mb-1">{{ download.title }}</h5>
                            <small>{{ format_size(download.total_size ?? 0) }}</small>
                        </div>
                        {% if download.description %}
                            <p class="mb-1 text-truncate">{{ download.description|striptags }}</p>
                        {% endif %}
                        <small class="text-muted">{{ download.category_title ?? '' }}</small>
                    </a>
                {% endfor %}
            </div>

            {% if pagination is defined and pagination %}
                <nav class="mt-4">{{ pagination|raw }}</nav>
            {% endif %}
        {% else %}
            <div class="alert alert-info">No results found for &ldquo;{{ searchword }}&rdquo;.</div>
        {% endif %}
    {% endif %}
</div>
