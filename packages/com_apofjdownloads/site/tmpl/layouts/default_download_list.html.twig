<div class="apofjdl-download-list">
    {% if downloads is not empty %}
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th class="text-end">Size</th>
                    <th class="text-end">Downloads</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                {% for download in downloads %}
                    <tr>
                        <td>
                            <a href="{{ download.link ?? '#' }}">{{ download.title }}</a>
                        </td>
                        <td>{{ download.category_title ?? '' }}</td>
                        <td class="text-end">{{ format_size(download.total_size ?? 0) }}</td>
                        <td class="text-end">{{ download.hits ?? 0 }}</td>
                        <td>{{ download.created ? format_date(download.created) : '' }}</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <div class="alert alert-info">No downloads available.</div>
    {% endif %}

    {% if pagination is defined and pagination %}
        <nav class="mt-4">{{ pagination|raw }}</nav>
    {% endif %}
</div>
