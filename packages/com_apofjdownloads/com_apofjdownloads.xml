<?xml version="1.0" encoding="UTF-8"?>
<extension type="component" method="upgrade">
    <name>COM_APOFJDOWNLOADS</name>
    <author>Apotentia LLC</author>
    <authorEmail>contact@apotentia.com</authorEmail>
    <authorUrl>https://apotentia.com</authorUrl>
    <copyright>(C) 2026 Apotentia LLC. All rights reserved.</copyright>
    <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
    <version>1.0.0</version>
    <creationDate>2026-02</creationDate>
    <description>COM_APOFJDOWNLOADS_DESCRIPTION</description>

    <namespace path="src">Apotentia\Component\ApofjDownloads</namespace>

    <install>
        <sql>
            <file driver="mysql" charset="utf8">sql/install.mysql.utf8.sql</file>
        </sql>
    </install>

    <uninstall>
        <sql>
            <file driver="mysql" charset="utf8">sql/uninstall.mysql.utf8.sql</file>
        </sql>
    </uninstall>

    <files folder="site">
        <folder>src</folder>
        <folder>tmpl</folder>
        <folder>language</folder>
    </files>

    <media destination="com_apofjdownloads" folder="media">
        <folder>css</folder>
        <folder>js</folder>
    </media>

    <administration>
        <files folder="admin">
            <folder>forms</folder>
            <folder>language</folder>
            <folder>services</folder>
            <folder>sql</folder>
            <folder>src</folder>
            <folder>tmpl</folder>
        </files>

        <menu img="class:default">COM_APOFJDOWNLOADS</menu>

        <submenu>
            <menu link="option=com_apofjdownloads&amp;view=downloads"
                  view="downloads"
                  img="class:default">
                COM_APOFJDOWNLOADS_DOWNLOADS
            </menu>
            <menu link="option=com_categories&amp;extension=com_apofjdownloads"
                  view="categories"
                  img="class:category">
                COM_APOFJDOWNLOADS_CATEGORIES
            </menu>
            <menu link="option=com_apofjdownloads&amp;view=files"
                  view="files"
                  img="class:file">
                COM_APOFJDOWNLOADS_FILES
            </menu>
            <menu link="option=com_apofjdownloads&amp;view=licenses"
                  view="licenses"
                  img="class:contract">
                COM_APOFJDOWNLOADS_LICENSES
            </menu>
            <menu link="option=com_apofjdownloads&amp;view=logs"
                  view="logs"
                  img="class:list">
                COM_APOFJDOWNLOADS_LOGS
            </menu>
            <menu link="option=com_apofjdownloads&amp;view=layouts"
                  view="layouts"
                  img="class:brush">
                COM_APOFJDOWNLOADS_LAYOUTS
            </menu>
        </submenu>
    </administration>

    <config>
        <fieldset name="component"
                  label="COM_APOFJDOWNLOADS_CONFIG_LABEL"
                  description="COM_APOFJDOWNLOADS_CONFIG_DESC">

            <field name="file_storage_path"
                   type="text"
                   label="COM_APOFJDOWNLOADS_CONFIG_STORAGE_PATH_LABEL"
                   description="COM_APOFJDOWNLOADS_CONFIG_STORAGE_PATH_DESC"
                   default="media/com_apofjdownloads/files"
                   filter="path" />

            <field name="default_access"
                   type="accesslevel"
                   label="COM_APOFJDOWNLOADS_CONFIG_DEFAULT_ACCESS_LABEL"
                   description="COM_APOFJDOWNLOADS_CONFIG_DEFAULT_ACCESS_DESC"
                   default="1" />

            <field name="token_ttl"
                   type="number"
                   label="COM_APOFJDOWNLOADS_CONFIG_TOKEN_TTL_LABEL"
                   description="COM_APOFJDOWNLOADS_CONFIG_TOKEN_TTL_DESC"
                   default="3600"
                   min="60"
                   max="86400"
                   step="60" />

            <field name="rate_limit_per_minute"
                   type="number"
                   label="COM_APOFJDOWNLOADS_CONFIG_RATE_LIMIT_LABEL"
                   description="COM_APOFJDOWNLOADS_CONFIG_RATE_LIMIT_DESC"
                   default="10"
                   min="1"
                   max="1000" />

            <field name="enable_xsendfile"
                   type="radio"
                   label="COM_APOFJDOWNLOADS_CONFIG_XSENDFILE_LABEL"
                   description="COM_APOFJDOWNLOADS_CONFIG_XSENDFILE_DESC"
                   default="0"
                   class="btn-group">
                <option value="0">JNO</option>
                <option value="1">JAPACHE_XSENDFILE</option>
                <option value="2">JNGINX_XACCEL</option>
            </field>
        </fieldset>

        <fieldset name="permissions"
                  label="JCONFIG_PERMISSIONS_LABEL"
                  description="JCONFIG_PERMISSIONS_DESC">
            <field name="rules"
                   type="rules"
                   label="JCONFIG_PERMISSIONS_LABEL"
                   filter="rules"
                   validate="rules"
                   component="com_apofjdownloads"
                   section="component" />
        </fieldset>
    </config>
</extension>
